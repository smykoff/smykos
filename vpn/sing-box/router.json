{
  "log": { "level": "info" },

  "inbounds": [
    { "type": "mixed", "tag": "in", "listen": "127.0.0.1", "listen_port": 1090 }
  ],

  "outbounds": [
    { "type": "http", "tag": "my", "server": "127.0.0.1", "server_port": 1081 },
    { "type": "http", "tag": "nixoswg", "server": "127.0.0.1", "server_port": 1080 },
    { "type": "direct", "tag": "direct" },
    { "type": "block", "tag": "block" }
  ],

  "route": {
    "rules": [
      { "rule_set": [ "ru-bundle" ], "outbound": "my" }
    ],

    "rule_set": [
      {
        "type": "remote",
        "tag": "ru-bundle",
        "format": "binary",
        "url": "https://github.com/legiz-ru/sb-rule-sets/raw/main/ru-bundle.srs"
      }
    ],

    "final": "direct"
  },

  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/var/cache/sing-box/router.json"
    }
  }
}
